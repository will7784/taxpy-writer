# ============================================
# Telegram (obligatorio)
# ============================================
TELEGRAM_BOT_TOKEN=tu_token_de_botfather

# ============================================
# OpenAI — escritura con GPT-4o (obligatorio)
# ============================================
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ============================================
# Google Gemini — voz STT/TTS (opcional pero recomendado)
# ============================================
GOOGLE_API_KEY=tu_api_key_de_google_ai_studio

# ============================================
# NotebookLM (obligatorio)
# ============================================
NOTEBOOKLM_NOTEBOOK_NAME=Taxpy Conocimiento

# Para deploy en Railway / servidores sin navegador:
# 1. Ejecuta 'notebooklm login' en tu PC local
# 2. Copia el contenido de: ~/.notebooklm/profiles/default/storage_state.json
# 3. Pégalo aquí como una sola línea (quita saltos de línea)
# NOTEBOOKLM_AUTH_JSON={"cookies":[...]}

# ============================================
# Writer (opcional, valores por defecto razonables)
# ============================================
# WRITER_MAX_TOKENS=4000
# WRITER_TEMPERATURE=0.5

# ============================================
# Paths (opcional)
# ============================================
# TELEGRAM_DB_PATH=./taxpy_writer.sqlite3
# EXPORTS_DIR=./exports
